---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "배기민 (BAEM1N)",
  alternateName: "baem1n",
  url: SITE.website,
  mainEntityOfPage: `${SITE.website}about/`,
  jobTitle: "AI/Data Educator & Engineer",
  worksFor: {
    "@type": "Organization",
    name: "DDOK.AI",
  },
  affiliation: {
    "@type": "Organization",
    name: "DDOK.AI",
  },
  email: "gm.bae@ddok.ai",
  description:
    "AI/Data Educator & Engineer. TensorFlow Certificate, 빅데이터분석기사. Samsung, SK, GS 등 기업 AI 교육. LangChain-OpenTutorial 인프라 PM.",
  knowsAbout: [
    "Data Science",
    "Machine Learning",
    "Deep Learning",
    "RAG",
    "AI Agent",
    "LLMOps",
    "LangChain",
    "Local LLM Inference",
    "Benchmark Engineering",
  ],
  hasCredential: [
    {
      "@type": "EducationalOccupationalCredential",
      credentialCategory: "Professional Certificate",
      name: "TensorFlow Certificate",
    },
    {
      "@type": "EducationalOccupationalCredential",
      credentialCategory: "Professional Certification",
      name: "Big Data Analytics Engineer",
    },
  ],
  contactPoint: {
    "@type": "ContactPoint",
    email: "gm.bae@ddok.ai",
    contactType: "AI/data education and technical project inquiries",
    availableLanguage: ["ko", "en"],
  },
  sameAs: [
    "https://github.com/baem1n",
    "https://www.linkedin.com/in/baem1n/",
    "https://huggingface.co/baem1n",
  ],
};
---

{/* Detect EN about page by checking URL path */}
<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  lang={Astro.url.pathname.startsWith("/en/") ? "en" : "ko"}
  alternateUrl={Astro.url.pathname.startsWith("/en/")
    ? `${SITE.website}about/`
    : `${SITE.website}en/about/`}
  alternateLang={Astro.url.pathname.startsWith("/en/") ? "ko" : "en"}
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(personJsonLd)}
  />
</Layout>
